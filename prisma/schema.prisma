generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  PARTICIPANT
  MENTOR
  PARTNER
}

enum RegistrationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BusinessIdeaStatus {
  DRAFT
  SUBMITTED
  IN_REVIEW
  APPROVED
  NEEDS_REVISION
}

model User {
  id              String              @id @default(cuid())
  name            String
  email           String              @unique
  passwordHash    String
  role            Role
  status          String              @default("ACTIVE")
  participant     ParticipantProfile?
  mentorSessions  MentoringSession[]  @relation("MentorSessions")
  sentMessages     Message[]          @relation("SentMessages")
  receivedMessages Message[]          @relation("ReceivedMessages")
  auditLogs        AuditLog[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
}

model ParticipantProfile {
  id             String          @id @default(cuid())
  userId         String          @unique
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  disabilityNeed String
  localPotential String
  address        String
  consentStatus  Boolean         @default(false)
  registrations  Registration[]
  assessments    Assessment[]
  attendances    Attendance[]
  progressRecords ProgressRecord[]
  mentoringSessions MentoringSession[] @relation("ParticipantSessions")
  businessIdeas  BusinessIdea[]
  products       Product[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Program {
  id            String          @id @default(cuid())
  name          String
  type          String
  description   String
  period        String
  status        String          @default("OPEN")
  registrations Registration[]
  modules       TrainingModule[]
  schedules     Schedule[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model Registration {
  id            String             @id @default(cuid())
  participantId String
  programId     String
  status        RegistrationStatus @default(PENDING)
  participant   ParticipantProfile @relation(fields: [participantId], references: [id], onDelete: Cascade)
  program       Program            @relation(fields: [programId], references: [id], onDelete: Cascade)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
}

model Assessment {
  id             String             @id @default(cuid())
  participantId  String
  score          Int
  recommendation String
  notes          String
  participant    ParticipantProfile @relation(fields: [participantId], references: [id], onDelete: Cascade)
  createdAt      DateTime           @default(now())
}

model TrainingModule {
  id          String           @id @default(cuid())
  programId   String
  title       String
  description String
  materialUrl String?
  program     Program          @relation(fields: [programId], references: [id], onDelete: Cascade)
  progress    ProgressRecord[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model Schedule {
  id          String       @id @default(cuid())
  programId   String
  title       String
  date        DateTime
  location    String
  program     Program      @relation(fields: [programId], references: [id], onDelete: Cascade)
  attendances Attendance[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Attendance {
  id            String             @id @default(cuid())
  scheduleId    String
  participantId String
  status        String
  schedule      Schedule           @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  participant   ParticipantProfile @relation(fields: [participantId], references: [id], onDelete: Cascade)
  createdAt     DateTime           @default(now())
}

model ProgressRecord {
  id            String             @id @default(cuid())
  participantId String
  moduleId      String
  completion    Int
  notes         String
  participant   ParticipantProfile @relation(fields: [participantId], references: [id], onDelete: Cascade)
  module        TrainingModule     @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  updatedAt     DateTime           @updatedAt
}

model MentoringSession {
  id            String             @id @default(cuid())
  mentorId      String
  participantId String
  topic         String
  notes         String
  nextAction    String
  sessionDate   DateTime
  mentor        User               @relation("MentorSessions", fields: [mentorId], references: [id])
  participant   ParticipantProfile @relation("ParticipantSessions", fields: [participantId], references: [id])
  createdAt     DateTime           @default(now())
}

model Message {
  id          String   @id @default(cuid())
  senderId    String
  recipientId String
  subject     String
  body        String
  readAt      DateTime?
  sender      User     @relation("SentMessages", fields: [senderId], references: [id])
  recipient   User     @relation("ReceivedMessages", fields: [recipientId], references: [id])
  createdAt   DateTime @default(now())
}

model BusinessIdea {
  id            String             @id @default(cuid())
  participantId String
  title         String
  description   String
  localPotential String
  status        BusinessIdeaStatus @default(SUBMITTED)
  participant   ParticipantProfile @relation(fields: [participantId], references: [id], onDelete: Cascade)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
}

model Product {
  id            String             @id @default(cuid())
  participantId String
  name          String
  category      String
  description   String
  imageUrl      String?
  status        String             @default("PUBLISHED")
  participant   ParticipantProfile @relation(fields: [participantId], references: [id], onDelete: Cascade)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
}

model Report {
  id          String   @id @default(cuid())
  period      String
  type        String
  summary     String
  generatedBy String
  createdAt   DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String
  action    String
  object    String
  metadata  String?
  actor     User     @relation(fields: [actorId], references: [id])
  createdAt DateTime @default(now())
}
